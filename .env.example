# Supabase configuration (required for production)
# Copy this file to .env or .env.local and fill in your Supabase project values.
# Restart `npm run dev` after changing env vars.
# For Netlify/Vercel: set these as Environment Variables in the dashboard.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# System Admin (/system-admin): when both vars are set, login uses Supabase Auth (real JWT).
# Create an Auth user, then ensure public.users has a row with id = auth.users.id and role = 'SUPER_ADMIN'.
# Without these vars, the app falls back to UI-only simulation (no database writes; RLS needs auth.uid()).
